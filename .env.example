VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Canonical app URL used as the magic-link redirect target. Pinning this
# stops the auth flow from honouring whatever `window.location` happens to
# be — e.g. a preview deploy or a tampered origin. Leave unset in local
# dev to fall back to the current page origin.
# Production: https://sndrspk.github.io/NextDays/
VITE_APP_URL=

# ── Discord notifications (server-side secrets — never put in .env) ──────────
# Set these in GitHub repository secrets and via `supabase secrets set`:
#
#   SUPABASE_SERVICE_ROLE_KEY  → GitHub secret used by the daily-notification
#                                cron workflow to call the edge function.
#   DISCORD_BOT_TOKEN          → Supabase edge function secret used by
#                                send-daily-notification to post DMs.
#
# Both are purely server-side; they must never appear in .env or be shipped
# to the browser.
